{
  "name": "seciter-03-dep-upgrade",
  "version": "1.0.0",
  "description": "Dependency upgrade cascade exercise",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "test": "jest --testPathPattern=test/integration --forceExit --detectOpenHandles",
    "test:auth": "jest --testPathPattern=test/integration/auth.test.js --forceExit",
    "test:transform": "jest --testPathPattern=test/integration/transform.test.js --forceExit",
    "test:upload": "jest --testPathPattern=test/integration/upload.test.js --forceExit",
    "audit:check": "npm audit --production --audit-level=high"
  },
  "dependencies": {
    "express": "^4.18.2",
    "express-fileupload": "1.2.1",
    "jsonwebtoken": "8.5.1",
    "lodash": "4.17.15",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "jest": "^28.1.3",
    "supertest": "^6.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 15000
  }
}
